# h5-service 上线环境变量模板（含密钥，真实值请走部署环境/CI Secret，勿提交）。
# Spring Boot 直接读取这些环境变量（application.yml 已用 ${VAR:default} 占位）。

# ── H5 会话 / 加密 ──
H5_JWT_SECRET=                # H5 会话 JWT 密钥（HS256，>=32 字节随机串）
H5_AES_MASTER_KEY=            # 身份证号 AES-256 主密钥（32 字节 base64）
H5_PUBLIC_BASE_URL=https://h5.sanshuiyuan.com   # H5 公网根地址（拼实人认证回跳 ReturnUrl）

# ── 微信（网页授权 + 支付，同一公众号 appId）──
WXPAY_APP_ID=                 # 公众号 appId
WX_APP_SECRET=                # 公众号 appSecret（jscode2session 换 openid）
WXPAY_MCH_ID=                 # 商户号
WXPAY_API_V3_KEY=             # APIv3 密钥
WXPAY_MERCHANT_SERIAL_NUMBER= # 商户证书序列号
WXPAY_PRIVATE_KEY_PATH=       # 商户私钥 apiclient_key.pem 路径
WXPAY_NOTIFY_URL=https://api.sanshuiyuan.com/api/h5/pay/callback         # 支付结果回调（公网 https）
WXPAY_REFUND_NOTIFY_URL=https://api.sanshuiyuan.com/api/h5/pay/refund-callback  # 退款结果回调

# ── 阿里云活体检测（三水元 H5 场景）──
ALIYUN_KYC_ACCESS_KEY=
ALIYUN_KYC_SECRET_KEY=
ALIYUN_KYC_SCENE_ID=1000018706   # 三水元 H5 场景实人认证
ALIYUN_KYC_ENDPOINT=cloudauth.aliyuncs.com
ALIYUN_KYC_PRODUCT_CODE=LR_FR    # 活体检测方案
ALIYUN_KYC_MODEL=MOVE_ACTION     # 活体类型：远近移动+眨眼

# ── 数据库 / Redis ──
SPRING_DATASOURCE_URL=
DB_USERNAME=
DB_PASSWORD=
REDIS_HOST=
REDIS_PORT=
