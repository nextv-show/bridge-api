# ================================================================
# 三水元 ess-service 环境变量配置模板
# 腾讯电子签（ESS）企业版 API 对接
# ================================================================

# ---------- Spring Profile ----------
# 可选: test（联调/测试）, prod（生产）
SPRING_PROFILES_ACTIVE=test

# ---------- 腾讯电子签 API ----------
# 联调环境 SecretId（开发控制台 > 企业应用管理）
ESS_SECRET_ID=

# 联调环境 SecretKey（开发控制台 > 企业应用管理）
ESS_SECRET_KEY=

# API 接入点（联调: ess.test.ess.tencent.cn | 生产: ess.tencentcloudapi.com）
ESS_API_ENDPOINT=ess.test.ess.tencent.cn

# API Region（默认 ap-guangzhou）
ESS_API_REGION=ap-guangzhou

# 操作人 ID（开发控制台 > 企业应用管理 > 操作人）
ESS_OPERATOR_ID=

# 企业应用 ID / CorpId（开发控制台 > 企业应用管理）
ESS_CORP_ID=

# 合同模板 ID（腾讯电子签平台创建的模板）
ESS_TEMPLATE_ID=
# 是否在创建签署方时传身份证号（联调环境建议 false，生产环境可开启）
ESS_COLLECT_ID_CARD=false

# ---------- 回调 ----------
# 签署回调地址（需外部可访问）
ESS_CALLBACK_URL=https://api.sanshuiyuan.com/api/internal/ess/callback

# ---------- 数据库 ----------
SPRING_DATASOURCE_URL=jdbc:mysql://bridge-mysql:3306/ess_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Shanghai&characterEncoding=utf8mb4
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# ---------- Redis ----------
SPRING_DATA_REDIS_HOST=bridge-redis
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=

# ---------- MinIO 对象存储 ----------
OSS_ENDPOINT=http://bridge-minio:9000
OSS_ACCESS_KEY=
OSS_SECRET_KEY=
OSS_BUCKET_NAME=sanshuiyuan-contracts

# ---------- 服务配置 ----------
SERVER_PORT=8085

# Java 启动参数
JAVA_OPTS=-Djava.net.preferIPv4Stack=true
